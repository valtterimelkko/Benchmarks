[Unit]
Description=Private LLM benchmark dashboard static server container
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/benchmarks
ExecStartPre=-/usr/bin/docker rm -f benchmarks-dashboard
ExecStart=/usr/bin/docker run --name benchmarks-dashboard --network n8n-docker-caddy_default --read-only --tmpfs /tmp:rw,noexec,nosuid,size=16m --tmpfs /data:rw,noexec,nosuid,size=16m --tmpfs /config:rw,noexec,nosuid,size=16m -v /root/benchmarks/public:/srv:ro caddy:latest caddy file-server --listen :8766 --root /srv
ExecStop=/usr/bin/docker stop benchmarks-dashboard
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
